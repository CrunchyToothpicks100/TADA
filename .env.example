SECRET_KEY="replace_with_a_generated_django_secret_key"
DEBUG="False"

# Django deployment settings. For local smoke tests, include localhost.
ALLOWED_HOSTS="tada.fbstudios.com,localhost,127.0.0.1,192.168.22.170"
CSRF_TRUSTED_ORIGINS="https://tada.fbstudios.com"
SECURE_SSL_REDIRECT="False"
SECURE_HSTS_SECONDS="0"
SECURE_HSTS_INCLUDE_SUBDOMAINS="False"
SECURE_HSTS_PRELOAD="False"
SESSION_COOKIE_SECURE="False"
CSRF_COOKIE_SECURE="False"

# Host port for the reverse proxy to target. The default only listens locally
# so it should not collide with other public services on a shared startup host.
TADA_WEB_BIND="127.0.0.1"
TADA_WEB_PORT="8017"

# Postgres settings used by docker-compose.yml to create DATABASE_URL.
POSTGRES_DB="tada"
POSTGRES_USER="tadauser"
POSTGRES_PASSWORD="replace_with_a_strong_database_password"
